interface Node {
  id: ID!
}
enum SocialMediaPlatform {
  YOUTUBE
  FACEBOOK
  INSTAGRAM
  TIKTOK
  TWITTER
}
type SocialMediaProfileNode implements Node {
  platform: SocialMediaPlatform!
  url: AWSURL!
  id: ID!
}
type SocialMediaProfileNodeEdge {
  node: SocialMediaProfileNode!
  nextToken: String
}
type SocialMediaProfileNodeConnection {
  edges: [SocialMediaProfileNodeEdge]!
  SocialMediaProfileNodes: [SocialMediaProfileNode]!
  totalCount: Int!
}
type ArtistNode implements Node {
  name: String!
  bio: String!
  socialMediaProfiles: [SocialMediaProfileNode]!
  id: ID!
}
type ArtistNodeEdge {
  node: ArtistNode!
  nextToken: String
}
type ArtistNodeConnection {
  edges: [ArtistNodeEdge]!
  ArtistNodes: [ArtistNode]!
  totalCount: Int!
}
type Query {
  artist(id: ID!): ArtistNode
}
